# Copy this file to .env and fill in real values before running.
# .env is git-ignored — never commit secrets.

# --- Outgoing: post messages to Mattermost ---
# Optional: send replies to a real Mattermost channel via incoming webhook.
# Leave unset to use stdout simulation (REPL mode).
# MATTERMOST_WEBHOOK_URL=https://your-mattermost.example.com/hooks/xxx

# --- Incoming: poll a Mattermost channel for commands ---
# All three vars below must be set to enable polling; any one missing disables it.
# MATTERMOST_SERVER_URL=https://your-mattermost.example.com
# MATTERMOST_TOKEN=your-personal-access-token
# MATTERMOST_CHANNEL_ID=abcdefghijklmnopqrstuvwxyz  # channel ID (not name)

# How often to poll for new messages (Go duration string, default 15s)
# MATTERMOST_POLL_INTERVAL=15s

# Keyword that must appear at the start of a message for the bot to act on it.
# The keyword is stripped before routing, so "@watchtower help" → dispatches "help".
# Default: @watchtower
# WATCHTOWER_KEYWORD=@watchtower

# --- General overrides (defaults shown) ---
# DEFAULT_RELEASE=noble       # empty = auto-detect most active release
# TEST_OBSERVER_URL=https://tests-api.ubuntu.com
# TEMPORAL_HOST=localhost:7233

# How often to poll for build/test changes (standard cron syntax, default every 10 min)
# Set to a longer interval to reduce API traffic, e.g. every 30 min or once an hour.
# WATCHTOWER_CRON_SCHEDULE=*/10 * * * *
# WATCHTOWER_CRON_SCHEDULE=*/30 * * * *   # every 30 min
# WATCHTOWER_CRON_SCHEDULE=0 * * * *      # every hour

# TODO: uncomment when log analysis is implemented
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# LLM_MODEL=anthropic/claude-sonnet-4-5
